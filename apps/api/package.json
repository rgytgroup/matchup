    "@prisma/client": "^5.19.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^16.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "prisma": "^5.19.1",
    "typescript": "^5.5.4"
  }
