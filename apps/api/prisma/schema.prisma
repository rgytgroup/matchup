// Modelo de datos de MatchUp (SPEC §3). Prisma es la ÚNICA capa de acceso a datos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Tier {
  AUDIT
  AUDIT_PLUS_PHOTOS
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum SubmissionStatus {
  UPLOADED
  EXTRACTING
  CONFIRMING
  ANALYZING
  DONE
  FAILED
  NEEDS_ATTENTION
}

enum IntakeMode {
  SCREENSHOTS
  MANUAL
}

enum PhotoJobStatus {
  QUEUED
  TRAINING
  GENERATING
  QC
  DONE
  FAILED
  NEEDS_ATTENTION
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  tier                  Tier
  stripeSessionId       String?     @unique
  stripePaymentIntentId String?     @unique
  status                OrderStatus @default(PENDING)
  amountUsd       Decimal     @db.Decimal(10, 2)
  createdAt       DateTime    @default(now())
  submission      Submission?
  photoJob        PhotoJob?
}

model Submission {
  id               String           @id @default(cuid())
  orderId          String           @unique
  order            Order            @relation(fields: [orderId], references: [id])
  intakeMode       IntakeMode       @default(MANUAL)
  screenshotUrls   String[]         @default([])
  extractedProfile Json? // §5.0: platform, bioText, prompts[], photoRefs[], confidence
  platform         String? // plataforma resuelta (detectada o elegida): tinder|hinge|bumble|other
  questionnaire    Json
  bioText          String
  photoUrls        String[]
  status           SubmissionStatus @default(UPLOADED)
  retryCount       Int              @default(0)
  lastError        String?
  createdAt        DateTime         @default(now())
  report           Report?
}

model Report {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id])
  resultJson   Json
  pdfUrl       String?
  publicSlug   String     @unique
  createdAt    DateTime   @default(now())
}

model PhotoJob {
  id           String         @id @default(cuid())
  orderId      String         @unique
  order        Order          @relation(fields: [orderId], references: [id])
  provider     String
  trainingId   String?
  status       PhotoJobStatus @default(QUEUED)
  outputUrls   String[]
  acceptedUrls String[]
  qcScoredUrls Json           @default("[]") // urls ya puntuadas en QC (para reanudar sin re-puntuar, §11.2)
  retryCount   Int            @default(0)
  lastError    String?
  costUsd      Decimal?       @db.Decimal(10, 2)
  createdAt    DateTime       @default(now())
}

// Lista de lanzamiento capturada por la puerta falsa (SPEC §3, §12).
model Lead {
  id               String   @id @default(cuid())
  email            String
  teaserScore      Int // score mostrado en el teaser (0-100)
  priceShown       Decimal  @db.Decimal(10, 2) // para el A/B de §12.1.5
  variant          String? // variante de precio mostrada
  source           String? // utm/canal (tiktok|reddit|directory|share|...)
  country          String? // código de país (§12.2.2) — NUNCA se guarda la IP
  submissionId     String? // FK suave opcional a Submission
  convertedOrderId String? // se llena cuando el lead compra de verdad (§12.6)
  createdAt        DateTime @default(now())

  @@index([email])
}

// Analítica interna mínima (SPEC §3): visita checkout, compra, reembolso, etc.
model Event {
  id        String   @id @default(cuid())
  type      String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([type])
}

// Ledger de idempotencia de webhooks de Stripe (SPEC §8/§9):
// procesar el mismo evento dos veces no puede duplicar análisis/emails/jobs.
model ProcessedWebhook {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  createdAt     DateTime @default(now())
}
