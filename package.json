{
  "name": "matchup",
  "version": "0.0.0",
  "private": true,
  "description": "Auditoría honesta de perfiles de citas con IA. Producto de rgytgroup.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:web": "npm run dev --workspace @matchup/web",
    "dev:api": "npm run start:dev --workspace @matchup/api"
  }
}
