# MatchUp — variables de entorno (SPEC §7)
# Copiar a .env y llenar con valores reales. NUNCA commitear .env.
# Los valores reales viven en el gestor de secretos de rgytgroup.

# --- Base de datos (Supabase Postgres) ---
DATABASE_URL="postgresql://user:password@host:5432/matchup?schema=public"

# --- Supabase (auth magic link + storage privado) ---
SUPABASE_URL=""
SUPABASE_SERVICE_KEY=""

# --- IA de análisis (Google Gemini, visión + texto, salida JSON) ---
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# --- IA de fotos (Replicate: entrenamiento LoRA + generación) ---
REPLICATE_API_TOKEN=""
# Modelo de entrenamiento (ej. "ostris/flux-dev-lora-trainer:<version>") y modelo base para generar.
REPLICATE_TRAINING_MODEL=""
REPLICATE_BASE_MODEL=""

# --- Pagos (Stripe Checkout + webhooks) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY=""
# Remitente verificado en Resend (para pruebas puedes usar onboarding@resend.dev).
EMAIL_FROM="MatchUp <onboarding@resend.dev>"

# --- Storage (Supabase) ---
SUPABASE_BUCKET="submissions"

# --- App ---
APP_BASE_URL="http://localhost:5173"

# --- Operación (no en SPEC §7, pero necesarios en runtime) ---
PORT="3000"
ADMIN_ALERT_EMAIL=""
